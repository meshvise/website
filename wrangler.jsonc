{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wiregrid-vitrine",
  "compatibility_date": "2026-04-23",
  "main": "src/worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "wiregrid.fr", "custom_domain": true },
    { "pattern": "www.wiregrid.fr", "custom_domain": true }
  ]
}
