---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { FAQ_KEYS } from '../i18n/faq-keys';
import { t, type Lang } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogImage?: string;
}

const { title, description, lang, ogImage = '/og-image.svg' } = Astro.props;

const SITE_ORIGIN = 'https://wiregrid.fr';
const alternateLang: Lang = lang === 'fr' ? 'en' : 'fr';
const currentPath = Astro.url.pathname;
const alternatePath =
  currentPath.replace(`/${lang}/`, `/${alternateLang}/`).replace(`/${lang}`, `/${alternateLang}`) ||
  `/${alternateLang}/`;
const canonicalUrl = `${SITE_ORIGIN}${currentPath}`;
const alternateUrl = `${SITE_ORIGIN}${alternatePath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_ORIGIN}${ogImage}`;

const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const ogLocaleAlternate = alternateLang === 'fr' ? 'fr_FR' : 'en_US';

// Strip HTML tags for JSON-LD plain-text answers (no markup allowed there).
const stripHtml = (s: string) =>
  s.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Wiregrid',
  url: SITE_ORIGIN,
  logo: `${SITE_ORIGIN}/favicon.svg`,
  description,
  email: 'contact@wiregrid.fr',
  sameAs: ['https://www.linkedin.com/in/bruno-crespo'],
};

const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Wiregrid',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'SCADA / Industrial Supervision',
  operatingSystem: 'Linux, Windows, macOS (Docker)',
  description,
  url: SITE_ORIGIN,
  inLanguage: ['fr', 'en'],
  softwareVersion: '0.1.0',
  offers: [
    {
      '@type': 'Offer',
      name: lang === 'fr' ? 'Découverte' : 'Discovery',
      price: '0',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
      url: 'https://demo.wiregrid.fr',
      description:
        lang === 'fr'
          ? 'Self-host gratuit jusqu’à 50 points, Modbus TCP, 7 jours d’historique.'
          : 'Free self-host up to 50 points, Modbus TCP, 7-day history.',
    },
    {
      '@type': 'Offer',
      name: 'Production',
      price: '990',
      priceCurrency: 'EUR',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '990',
        priceCurrency: 'EUR',
        billingDuration: 'P1Y',
        unitText: 'YEAR',
      },
      availability: 'https://schema.org/InStock',
      url: `${SITE_ORIGIN}/${lang}/#pricing`,
      description:
        lang === 'fr'
          ? 'Points illimités, Modbus + OPC-UA + BACnet, historian illimité, support email + visio.'
          : 'Unlimited points, Modbus + OPC-UA + BACnet, unlimited historian, email + video support.',
    },
  ],
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_KEYS.map((key) => ({
    '@type': 'Question',
    name: t(lang, `faq.${key}.q`),
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(t(lang, `faq.${key}.a_html`)),
    },
  })),
};
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#06B6D4" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={`${SITE_ORIGIN}/`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Wiregrid" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t(lang, 'meta.og_image_alt')} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Schema.org structured data — feeds Google rich results AND
         AI search citations (Perplexity, ChatGPT, Claude). FAQPage in
         particular gets re-quoted verbatim in answer engines. -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </head>
  <body class="bg-bg text-text antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-3 focus:py-2 focus:rounded-sm focus:bg-brand focus:text-bg focus:font-medium focus:outline-2 focus:outline-offset-2 focus:outline-brand"
    >
      {t(lang, 'a11y.skip_to_content')}
    </a>
    <Header lang={lang} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
