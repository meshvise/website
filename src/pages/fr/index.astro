---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Personas from '../../components/Personas.astro';
import Features from '../../components/Features.astro';
import Lifecycle from '../../components/Lifecycle.astro';
import Pricing from '../../components/Pricing.astro';
import FAQ from '../../components/FAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const lang = 'fr' as const;
---

<Base
  lang={lang}
  title="Wiregrid · Supervision SCADA web sans tag-pricing"
  description="Une supervision SCADA web qui lit vos automates Modbus TCP, OPC-UA et BACnet/IP, historise, organise, alerte. Vos données accessibles directement par Power BI, Grafana ou Excel. Pas de licence par tag, version gratuite."
>
  <Hero lang={lang} />
  <Personas lang={lang} />
  <Features lang={lang} />
  <Lifecycle lang={lang} />
  <Pricing lang={lang} />
  <FAQ lang={lang} />
  <FinalCTA lang={lang} />
</Base>
