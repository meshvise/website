---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Personas from '../../components/Personas.astro';
import Features from '../../components/Features.astro';
import Lifecycle from '../../components/Lifecycle.astro';
import Pricing from '../../components/Pricing.astro';
import FAQ from '../../components/FAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const lang = 'en' as const;
---

<Base
  lang={lang}
  title="Wiregrid · Web SCADA without tag pricing"
  description="A web SCADA platform that reads your Modbus TCP, OPC-UA and BACnet/IP PLCs, historises, organises and alerts. Your data accessible directly by Power BI, Grafana or Excel. No per-tag licensing, free tier."
>
  <Hero lang={lang} />
  <Personas lang={lang} />
  <Features lang={lang} />
  <Lifecycle lang={lang} />
  <Pricing lang={lang} />
  <FAQ lang={lang} />
  <FinalCTA lang={lang} />
</Base>
