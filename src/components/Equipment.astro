---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const protocols = [
  {
    id: 'modbus',
    title: 'Modbus TCP',
    spec: 'TCP/502',
    refs: ['Schneider M340', 'Schneider M580', 'Siemens S7-1500', 'ABB AC500', 'Wago 750-89x', 'Phoenix Contact ILC'],
  },
  {
    id: 'opcua',
    title: 'OPC-UA',
    spec: 'IEC 62541',
    refs: ['Siemens S7-1500 (natif)', 'Schneider M580', 'Beckhoff TwinCAT', 'B&R X20', 'KEPServerEX'],
  },
  {
    id: 'bacnet',
    title: 'BACnet/IP',
    spec: 'ASHRAE 135',
    refs: ['Distech ECY', 'Honeywell WEBs', 'Trend IQ4', 'Siemens Desigo', 'JCI Metasys'],
  },
];
---

<section id="equipment" class="px-6 py-24 md:py-32 border-t border-border/60" style="background:var(--color-bg-alt);">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <div class="section-eyebrow justify-center">{t(lang, 'equipment.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'equipment.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'equipment.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {protocols.map((p) => (
        <div class="bg-surface rounded-lg border border-border p-7">
          <div class="flex items-baseline justify-between mb-5">
            <h3 class="font-semibold text-lg">{p.title}</h3>
            <span class="font-mono text-[11px] text-muted">{p.spec}</span>
          </div>
          <ul class="space-y-2 font-mono text-[13.5px]">
            {p.refs.map((r) => (
              <li class="text-muted-strong flex items-start gap-2">
                <span class="text-brand select-none">·</span>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="mt-8 text-[14px] text-muted-strong leading-relaxed max-w-3xl mx-auto text-center">{t(lang, 'equipment.note')}</p>
  </div>
</section>
