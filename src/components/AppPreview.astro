---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  compact?: boolean;
}

const { lang, compact = false } = Astro.props;

// Self-contained dark window: hardcoded colors so this stays dark even
// on the light marketing page. Mirrors apps/spa/src/style.css tokens
// (#0F172A, #1E293B, #06B6D4) — the visitor sees the actual product UI.
const points = [
  { id: 'ahu1_st',     path: 'AHU1/SupplyTemp',     unit: '°C', dyn: 'sine', base: 22.4, amp: 1.8, period: 11 },
  { id: 'ahu1_rt',     path: 'AHU1/ReturnTemp',     unit: '°C', dyn: 'sine', base: 24.1, amp: 1.4, period: 13 },
  { id: 'ahu1_fs',     path: 'AHU1/FanSpeed',       unit: '%',  dyn: 'walk', base: 78,   amp: 4,   period: 3 },
  { id: 'meter1_p',    path: 'Meter1/Power',        unit: 'kW', dyn: 'walk', base: 124.7, amp: 8,  period: 2, accent: true },
  { id: 'plant1_lv',   path: 'Plant1/Tank1/Level',  unit: '%',  dyn: 'sine', base: 62.3, amp: 6,   period: 17 },
  { id: 'boiler1_ft',  path: 'Boiler1/FlueTemp',    unit: '°C', dyn: 'sine', base: 247,  amp: 12,  period: 19 },
  { id: 'chiller1_st', path: 'Chiller1/SupplyTemp', unit: '°C', dyn: 'walk', base: 6.8,  amp: 0.4, period: 4 },
];
---

<figure
  id="app-preview"
  class={`relative rounded-xl shadow-2xl shadow-slate-900/15 ring-1 ring-slate-900/5 overflow-hidden ${compact ? '' : 'mx-auto max-w-5xl'}`}
  style="background:#0F172A;color:#F8FAFC;"
  role="img"
  aria-label={t(lang, 'app_preview.aria_label')}
>
  <div class="px-3 py-2 border-b flex items-center gap-2" style="background:#273449;border-color:#334155;">
    <div class="flex gap-1" aria-hidden="true">
      <span class="w-2 h-2 rounded-full" style="background:rgb(239 68 68 / 0.6);"></span>
      <span class="w-2 h-2 rounded-full" style="background:rgb(245 158 11 / 0.6);"></span>
      <span class="w-2 h-2 rounded-full" style="background:rgb(16 185 129 / 0.6);"></span>
    </div>
    <span class="text-[11px] font-mono ml-2" style="color:#94A3B8;">demo.wiregrid.fr</span>
    <span class="ml-auto flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-wider" style="color:#22D3EE;">
      <span class="relative flex h-1.5 w-1.5">
        <span class="absolute inline-flex h-full w-full rounded-full ws-pulse" style="background:#22D3EE;opacity:0.75;" aria-hidden="true"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5" style="background:#22D3EE;"></span>
      </span>
      live · ws
    </span>
  </div>

  <div class="grid grid-cols-[160px_1fr] min-h-[380px]">
    <aside class="border-r px-2.5 py-3 flex flex-col gap-0.5 text-[12px]" style="background:#1E293B;border-color:#334155;">
      <div class="text-[9px] uppercase tracking-[0.12em] px-2 mb-2 font-mono" style="color:#94A3B8;">{t(lang, 'app_preview.nav.section')}</div>
      <a class="px-2 py-1 rounded text-[#94A3B8]">{t(lang, 'app_preview.nav.overview')}</a>
      <a class="px-2 py-1 rounded text-[#94A3B8] flex items-center justify-between">
        <span>{t(lang, 'app_preview.nav.drivers')}</span>
        <span class="text-[10px] font-mono opacity-60">10</span>
      </a>
      <a class="px-2 py-1 rounded text-[#94A3B8] flex items-center justify-between">
        <span>{t(lang, 'app_preview.nav.machines')}</span>
        <span class="text-[10px] font-mono opacity-60">13</span>
      </a>
      <a class="px-2 py-1 rounded font-medium flex items-center justify-between" style="background:rgb(6 182 212 / 0.1);color:#22D3EE;">
        <span>{t(lang, 'app_preview.nav.live')}</span>
        <span class="text-[10px] font-mono opacity-80">52</span>
      </a>
      <a class="px-2 py-1 rounded text-[#94A3B8] flex items-center justify-between">
        <span>{t(lang, 'app_preview.nav.alarms')}</span>
        <span class="text-[10px] font-mono" style="color:rgb(245 158 11 / 0.8);">3</span>
      </a>
      <a class="px-2 py-1 rounded text-[#94A3B8]">{t(lang, 'app_preview.nav.revisions')}</a>

      <div class="mt-auto pt-3 px-1.5 border-t text-[10px] font-mono" style="border-color:#334155;color:#94A3B8;">
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full" style="background:#22D3EE;"></span>
          <span>{t(lang, 'app_preview.deployed_rev')}</span>
          <span style="color:#22D3EE;">#42</span>
        </div>
      </div>
    </aside>

    <div class="px-4 py-3 overflow-hidden">
      <div class="flex items-center justify-between mb-2.5">
        <h3 class="text-[12px] font-semibold tracking-tight" style="color:#F8FAFC;">{t(lang, 'app_preview.title')}</h3>
        <span class="text-[10px] font-mono" id="ap-status" style="color:#94A3B8;">↻ 0.4s</span>
      </div>

      <table class="w-full text-[12px] font-mono border-collapse">
        <thead>
          <tr class="text-[9px] uppercase tracking-wider border-b" style="color:#94A3B8;border-color:#334155;">
            <th class="text-left py-1.5 pr-3 font-medium">{t(lang, 'app_preview.col.path')}</th>
            <th class="text-right py-1.5 px-3 font-medium">{t(lang, 'app_preview.col.value')}</th>
            <th class="text-left py-1.5 px-2 font-medium">{t(lang, 'app_preview.col.unit')}</th>
            <th class="text-center py-1.5 pl-3 font-medium hidden sm:table-cell">{t(lang, 'app_preview.col.trend')}</th>
          </tr>
        </thead>
        <tbody>
          {points.map((p) => (
            <tr class="border-b last:border-0" data-point={p.id} style="border-color:rgb(51 65 85 / 0.5);">
              <td class="py-1.5 pr-3 truncate" style="color:#CBD5E1;">{p.path}</td>
              <td class="py-1.5 px-3 text-right tabular-nums" style={`color:${p.accent ? '#22D3EE' : '#F8FAFC'};font-weight:${p.accent ? '600' : '400'};`}>
                <span class="ap-val">{p.base.toFixed(p.unit === '%' ? 0 : 1)}</span>
              </td>
              <td class="py-1.5 px-2 text-[11px]" style="color:#94A3B8;">{p.unit}</td>
              <td class="py-1.5 pl-3 hidden sm:table-cell">
                <svg class="ap-spark mx-auto block w-20 h-4" viewBox="0 0 80 16" fill="none" stroke="rgb(34 211 238 / 0.7)" stroke-width="1.25" aria-hidden="true">
                  <polyline class="ap-spark-line" points="" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</figure>

<style>
  @keyframes ws-ping {
    0% { transform: scale(1); opacity: 0.75; }
    75%, 100% { transform: scale(2.4); opacity: 0; }
  }
  .ws-pulse { animation: ws-ping 1.6s cubic-bezier(0, 0, 0.2, 1) infinite; }
  @media (prefers-reduced-motion: reduce) { .ws-pulse { animation: none; } }
</style>

<script is:inline type="module" define:vars={{ pointsConfig: points }}>
  const figure = document.getElementById('app-preview');
  if (figure) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduced) {
      const buffers = new Map();
      const minMax = new Map();
      pointsConfig.forEach((p) => {
        buffers.set(p.id, Array(24).fill(p.base));
        minMax.set(p.id, { min: p.base - p.amp, max: p.base + p.amp });
      });

      const status = figure.querySelector('#ap-status');
      const t0 = performance.now();
      let lastUpdate = t0;

      const computeValue = (p, tSec) => {
        const buf = buffers.get(p.id);
        const last = buf[buf.length - 1];
        if (p.dyn === 'sine') {
          return p.base + p.amp * Math.sin((tSec * 2 * Math.PI) / p.period);
        }
        const drift = (Math.random() - 0.5) * p.amp * 0.18;
        const pull = (p.base - last) * 0.05;
        return last + drift + pull;
      };

      const render = (now) => {
        const tSec = (now - t0) / 1000;
        const since = ((now - lastUpdate) / 1000).toFixed(1);
        if (status) status.textContent = `↻ ${since}s`;

        if (now - lastUpdate < 280) {
          requestAnimationFrame(render);
          return;
        }
        lastUpdate = now;

        for (const p of pointsConfig) {
          const row = figure.querySelector(`tr[data-point="${p.id}"]`);
          if (!row) continue;
          const val = computeValue(p, tSec);
          const buf = buffers.get(p.id);
          buf.shift();
          buf.push(val);
          const valEl = row.querySelector('.ap-val');
          if (valEl) valEl.textContent = val.toFixed(1);
          const line = row.querySelector('.ap-spark-line');
          if (line) {
            const mm = minMax.get(p.id);
            const range = mm.max - mm.min || 1;
            const pts = buf.map((v, i) => {
              const x = (i / (buf.length - 1)) * 80;
              const y = 14 - ((v - mm.min) / range) * 12;
              return `${x.toFixed(1)},${y.toFixed(1)}`;
            }).join(' ');
            line.setAttribute('points', pts);
          }
        }
        requestAnimationFrame(render);
      };

      requestAnimationFrame(render);
    }
  }
</script>
