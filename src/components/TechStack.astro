---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const techs = [
  { name: 'PostgreSQL', color: '#336791' },
  { name: 'TimescaleDB', color: '#FDB515' },
  { name: 'Docker', color: '#2496ED' },
  { name: 'Python', color: '#3776AB' },
  { name: 'Laravel', color: '#FF2D20' },
  { name: 'Vue.js', color: '#4FC08D' },
  { name: 'Redis', color: '#DC382D' },
];
---

<section class="py-16 px-6">
  <div class="mx-auto max-w-4xl text-center">
    <p class="text-muted text-sm uppercase tracking-widest mb-8">{t(lang, 'tech.title')}</p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
      {techs.map((tech) => (
        <div class="flex items-center gap-2 text-muted hover:text-text transition-colors">
          <span class="w-3 h-3 rounded-full inline-block" style={`background-color: ${tech.color}`}></span>
          <span class="font-mono text-sm">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
