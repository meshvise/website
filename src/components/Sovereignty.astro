---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const cards = [
  { id: 'hosting',  icon: 'server' },
  { id: 'gdpr',     icon: 'shield' },
  { id: 'law',      icon: 'scale'  },
  { id: 'no_cloud', icon: 'globe'  },
];
---

<section id="sovereignty" class="px-6 py-24 md:py-32 border-t border-border/60" style="background:var(--color-bg-alt);">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="section-eyebrow justify-center">{t(lang, 'sovereignty.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'sovereignty.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'sovereignty.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {cards.map((card) => (
        <article class="bg-surface rounded-lg border border-border p-6 flex flex-col">
          <div class="w-9 h-9 rounded-md bg-brand-soft text-brand flex items-center justify-center shrink-0 mb-4">
            {card.icon === 'server' && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="3" y="4" width="18" height="6" rx="1.5"/>
                <rect x="3" y="14" width="18" height="6" rx="1.5"/>
                <circle cx="7" cy="7" r="0.6" fill="currentColor"/>
                <circle cx="7" cy="17" r="0.6" fill="currentColor"/>
              </svg>
            )}
            {card.icon === 'shield' && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M12 3l8 3v6c0 4.5-3.5 8-8 9-4.5-1-8-4.5-8-9V6l8-3z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {card.icon === 'scale' && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M12 3v18M5 7h14M7 7l-3 6a3 3 0 0 0 6 0L7 7zM17 7l-3 6a3 3 0 0 0 6 0l-3-6z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 21h8" stroke-linecap="round"/>
              </svg>
            )}
            {card.icon === 'globe' && (
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <circle cx="12" cy="12" r="9"/>
                <path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" stroke-linecap="round"/>
              </svg>
            )}
          </div>
          <h3 class="font-semibold text-text text-[16px] tracking-tight mb-2">{t(lang, `sovereignty.${card.id}.title`)}</h3>
          <p class="text-[14px] text-muted-strong leading-relaxed flex-1" set:html={t(lang, `sovereignty.${card.id}.body_html`)} />
        </article>
      ))}
    </div>

    <p class="mt-10 text-center text-[13px] text-muted" set:html={t(lang, 'sovereignty.attribution_html')} />
  </div>
</section>
