---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="waitlist" class="py-24 px-6">
  <div class="mx-auto max-w-2xl text-center">
    <div class="p-10 rounded-md border border-brand/30 bg-brand/5">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4">{t(lang, 'waitlist.title')}</h2>
      <p class="text-muted-strong mb-8 text-lg">{t(lang, 'waitlist.desc')}</p>

      <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          name="email"
          required
          placeholder={t(lang, 'waitlist.placeholder')}
          class="flex-1 px-4 py-3 rounded-sm bg-bg border border-border text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent text-sm"
        />
        <button type="submit" class="btn btn-primary btn-lg whitespace-nowrap">
          {t(lang, 'waitlist.cta')}
        </button>
      </form>

      <p id="waitlist-success" class="hidden mt-4 text-success text-sm font-medium">
        {t(lang, 'waitlist.success')}
      </p>

      <p class="mt-6 text-xs text-muted">
        {lang === 'fr'
          ? 'Communications strictement limitées aux actualités produit. Désinscription à tout moment.'
          : 'Communications strictly limited to product news. Unsubscribe at any time.'}
      </p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const success = document.getElementById('waitlist-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
