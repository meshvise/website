---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Each feature lists what's actually shipped (vs roadmap). Status:
//   'live'    — works in the demo at demo.wiregrid.fr today
//   'roadmap' — planned, public ETA in copy
const features = [
  { id: 'drivers', icon: 'protocol', status: 'live' },
  { id: 'live', icon: 'pulse', status: 'live' },
  { id: 'historian', icon: 'chart', status: 'live' },
  { id: 'alarms', icon: 'bell', status: 'live' },
  { id: 'revisions', icon: 'git', status: 'live' },
  { id: 'integrations', icon: 'database', status: 'live' },
  { id: 'multitenant', icon: 'shield', status: 'live' },
  { id: 'wiresheet', icon: 'flow', status: 'roadmap' },
];
---

<section id="features" class="px-6 py-20 border-t border-border">
  <div class="mx-auto max-w-5xl">
    <div class="max-w-2xl">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">
        {t(lang, 'features.title')}
      </h2>
      <p class="mt-4 text-muted-strong leading-relaxed">{t(lang, 'features.subtitle')}</p>
    </div>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4">
      {features.map((f) => (
        <article class="rounded-md border border-border bg-surface p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-md bg-brand/10 text-brand flex items-center justify-center shrink-0">
              {f.icon === 'protocol' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13" stroke-linecap="round"/><circle cx="3.5" cy="6" r="1.5"/><circle cx="3.5" cy="12" r="1.5"/><circle cx="3.5" cy="18" r="1.5"/></svg>
              )}
              {f.icon === 'pulse' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12h4l3-9 4 18 3-9h4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              )}
              {f.icon === 'chart' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 3v18h18M7 14l4-4 4 4 5-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              )}
              {f.icon === 'bell' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 8 3 8H3s3-1 3-8M10 21a2 2 0 0 0 4 0" stroke-linecap="round" stroke-linejoin="round"/></svg>
              )}
              {f.icon === 'git' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="12" r="2.5"/><path d="M6 8.5v7M8.5 6.5h2.5a3 3 0 0 1 3 3v2.5M8.5 17.5h2.5a3 3 0 0 0 3-3V12" stroke-linecap="round"/></svg>
              )}
              {f.icon === 'database' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><ellipse cx="12" cy="5" rx="8" ry="2.5"/><path d="M4 5v6c0 1.4 3.6 2.5 8 2.5s8-1.1 8-2.5V5M4 11v6c0 1.4 3.6 2.5 8 2.5s8-1.1 8-2.5v-6"/></svg>
              )}
              {f.icon === 'shield' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              )}
              {f.icon === 'flow' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="4" width="6" height="5" rx="1"/><rect x="2" y="15" width="6" height="5" rx="1"/><rect x="16" y="9.5" width="6" height="5" rx="1"/><path d="M8 6.5h4a2 2 0 0 1 2 2v3m-6 6h4a2 2 0 0 0 2-2v-3" stroke-linecap="round"/></svg>
              )}
            </div>
            <h3 class="font-semibold text-text">{t(lang, `features.${f.id}.title`)}</h3>
            {f.status === 'roadmap' && (
              <span class="ml-auto text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-sm border border-warning/40 text-warning bg-warning/5 shrink-0">
                {t(lang, 'features.status.roadmap')}
              </span>
            )}
          </div>
          <p class="text-sm text-muted-strong leading-relaxed">{t(lang, `features.${f.id}.desc`)}</p>
        </article>
      ))}
    </div>
  </div>
</section>
