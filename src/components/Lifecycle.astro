---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Equipment + tags : conceptual, no code, no SQL.
// Each item has 4 tags (site / building / function / criticality).
// The middle column highlights the active filter, the right column
// shows the equipment that matches it. Static SVG/markup, no JS.
const ACTIVE_FILTER = { category: 'function', value: 'HVAC' };

const equipment = [
  { name: 'CTA Bâtiment A',   tags: { site: 'Nord', building: 'A', function: 'HVAC',     criticality: 'high' } },
  { name: 'Compteur Princ.',  tags: { site: 'Nord', building: 'A', function: 'energy',   criticality: 'critical' } },
  { name: 'Cuve Process T1',  tags: { site: 'Nord', building: 'B', function: 'process',  criticality: 'high' } },
  { name: 'CTA Bâtiment B',   tags: { site: 'Nord', building: 'B', function: 'HVAC',     criticality: 'medium' } },
  { name: 'Chaudière Nord',   tags: { site: 'Nord', building: 'A', function: 'HVAC',     criticality: 'high' } },
  { name: 'Pompe Recirc. P1', tags: { site: 'Nord', building: 'A', function: 'HVAC',     criticality: 'medium' } },
];

const matches = (item: typeof equipment[number]) =>
  item.tags[ACTIVE_FILTER.category as keyof typeof item.tags] === ACTIVE_FILTER.value;

// Versioning timeline events. Each row is intentionally human-readable
// (no commit hash, no transaction jargon).
const events = [
  { time: '14:02',  who: 'Bruno', desc_fr: 'Setpoint AHU1 ajusté à 22 °C',                desc_en: 'AHU1 setpoint adjusted to 22 °C',            status: 'deployed' as const },
  { time: '11:48',  who: 'Bruno', desc_fr: 'Nouvelle alarme : FlueTemp > 280 °C',         desc_en: 'New alarm: FlueTemp > 280 °C',               status: 'deployed' as const },
  { time: '10:13',  who: 'Julie', desc_fr: 'Marge de tolérance Cuve T1 modifiée',         desc_en: 'Tank T1 deadband adjusted',                  status: 'reverted' as const },
  { time: '09:55',  who: 'Bruno', desc_fr: 'Pompe Recirculation P1 ajoutée',              desc_en: 'Pump Recirculation P1 added',                status: 'deployed' as const },
  { time: lang === 'fr' ? 'hier'   : 'yesterday', who: 'Bruno', desc_fr: 'AHU2 renommée « CTA Bâtiment B »', desc_en: 'AHU2 renamed "CTA Building B"', status: 'deployed' as const },
  { time: lang === 'fr' ? '2 sem.' : '2 wks',     who: 'Bruno', desc_fr: 'Réorganisation des étiquettes site', desc_en: 'Site tag reorganisation',     status: 'deployed' as const },
];
---

<section id="lifecycle" class="px-6 py-24 md:py-32 border-t border-border/60">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <div class="section-eyebrow justify-center">{t(lang, 'lifecycle.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'lifecycle.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'lifecycle.subtitle')}</p>
    </div>

    <!-- Block 1: Tags ─ text left / visual right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center mb-24 md:mb-32">
      <div class="lg:col-span-5">
        <h3 class="text-2xl md:text-3xl font-semibold tracking-tight leading-tight mb-5">
          {t(lang, 'lifecycle.tags.title')}
        </h3>
        <p class="text-[16px] text-muted-strong leading-[1.65]" set:html={t(lang, 'lifecycle.tags.body_html')} />
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-xl border border-border bg-surface p-6 md:p-7 shadow-sm">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-5 md:gap-7 items-stretch">
            <!-- Left column: all equipment with their tags -->
            <div>
              <div class="text-[10px] font-mono uppercase tracking-[0.1em] text-muted mb-3">Équipements (6)</div>
              <ul class="space-y-2.5">
                {equipment.map((item) => {
                  const m = matches(item);
                  return (
                    <li class={`text-[12.5px] ${m ? '' : 'opacity-30'}`}>
                      <div class="font-medium text-text mb-1">{item.name}</div>
                      <div class="flex flex-wrap gap-1">
                        {Object.entries(item.tags).map(([k, v]) => {
                          const isActive = k === ACTIVE_FILTER.category && v === ACTIVE_FILTER.value;
                          return (
                            <span
                              class={`inline-flex items-center font-mono text-[10px] px-1.5 py-0.5 rounded ${isActive ? 'bg-brand text-white font-medium' : 'bg-bg-alt text-muted-strong'}`}
                            >
                              {k}:{v}
                            </span>
                          );
                        })}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>

            <!-- Middle column: active filter arrow (desktop only) -->
            <div class="hidden md:flex flex-col items-center justify-center">
              <div class="text-[10px] font-mono uppercase tracking-[0.1em] text-muted mb-2 text-center">{t(lang, 'lifecycle.tags.filter_label')}</div>
              <div class="bg-brand-soft border border-brand/30 rounded-md px-3 py-2 text-center">
                <div class="font-mono text-[10px] uppercase text-muted leading-tight">{ACTIVE_FILTER.category}</div>
                <div class="font-mono text-[14px] text-brand font-semibold leading-tight mt-0.5">{ACTIVE_FILTER.value}</div>
              </div>
              <svg class="mt-3 w-8 h-8 text-brand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>

            <!-- Right column: filtered result -->
            <div>
              <div class="text-[10px] font-mono uppercase tracking-[0.1em] text-brand mb-3">
                {t(lang, 'lifecycle.tags.result_label')} ({equipment.filter(matches).length})
              </div>
              <ul class="space-y-2.5">
                {equipment.filter(matches).map((item) => (
                  <li class="text-[12.5px]">
                    <div class="font-medium text-text">{item.name}</div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Block 2: Versioning ─ visual left / text right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-7 lg:order-1">
        <div class="rounded-xl border border-border bg-surface p-6 md:p-7 shadow-sm">
          <div class="text-[10px] font-mono uppercase tracking-[0.1em] text-muted mb-5">Journal des modifications</div>
          <ol class="space-y-0">
            {events.map((ev, i) => (
              <li class="grid grid-cols-[68px_72px_1fr_auto] items-center gap-3 py-2.5 border-b border-border/70 last:border-0">
                <span class="font-mono text-[12px] text-muted">{ev.time}</span>
                <span class="text-[13px] text-text font-medium">{ev.who}</span>
                <span class="text-[13.5px] text-muted-strong leading-snug">{lang === 'fr' ? ev.desc_fr : ev.desc_en}</span>
                {ev.status === 'deployed' ? (
                  <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full text-brand bg-brand-soft border border-brand/30">
                    {t(lang, 'lifecycle.versioning.status.deployed')}
                  </span>
                ) : (
                  <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full text-muted bg-bg-alt border border-border">
                    {t(lang, 'lifecycle.versioning.status.reverted')}
                  </span>
                )}
              </li>
            ))}
          </ol>
        </div>
      </div>

      <div class="lg:col-span-5 lg:order-2">
        <h3 class="text-2xl md:text-3xl font-semibold tracking-tight leading-tight mb-5">
          {t(lang, 'lifecycle.versioning.title')}
        </h3>
        <p class="text-[16px] text-muted-strong leading-[1.65]" set:html={t(lang, 'lifecycle.versioning.body_html')} />
      </div>
    </div>
  </div>
</section>
