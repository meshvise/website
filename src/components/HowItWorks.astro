---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const steps = [
  { id: '1_install',   tag: 'docker compose up -d' },
  { id: '2_configure', tag: 'Modbus · OPC-UA · BACnet' },
  { id: '3_operate',   tag: 'Power BI · Grafana · Excel' },
];
---

<section class="py-20 px-6 bg-surface border-t border-border">
  <div class="mx-auto max-w-5xl">
    <div class="max-w-2xl mb-14">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(lang, 'how.title')}</h2>
      <p class="mt-4 text-muted-strong leading-relaxed">{t(lang, 'how.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-6 left-[16.6%] right-[16.6%] h-px bg-border" aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div class="relative">
          <div
            class="w-12 h-12 rounded-full bg-brand text-bg flex items-center justify-center text-xl font-semibold mb-5 relative z-10 ring-4 ring-surface"
            aria-hidden="true"
          >
            {i + 1}
          </div>
          <h3 class="text-xl font-semibold mb-3">{t(lang, `how.${step.id}.title`)}</h3>
          <p class="text-muted-strong leading-relaxed mb-3 text-sm">{t(lang, `how.${step.id}.desc`)}</p>
          <span class="inline-block text-[11px] font-mono text-brand bg-brand/10 px-2.5 py-1 rounded-sm border border-brand/20">{step.tag}</span>
        </div>
      ))}
    </div>
  </div>
</section>
