---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const steps = [
  { id: '1_install',   tag: 'docker compose up -d' },
  { id: '2_configure', tag: 'Modbus · OPC-UA · BACnet' },
  { id: '3_operate',   tag: 'Power BI · Grafana · Excel' },
];
---

<section class="px-6 py-24 md:py-32 border-t border-border/60" style="background:var(--color-bg-alt);">
  <div class="mx-auto max-w-6xl">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="section-eyebrow justify-center">{t(lang, 'how.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'how.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'how.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {steps.map((step, i) => (
        <div class="relative bg-surface rounded-lg border border-border p-7 transition-colors hover:border-brand/40">
          <div class="flex items-baseline justify-between mb-5">
            <span class="font-mono text-[13px] text-brand font-medium">{String(i + 1).padStart(2, '0')}</span>
            <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full text-muted bg-bg-alt border border-border">
              {step.tag}
            </span>
          </div>
          <h3 class="text-xl font-semibold tracking-tight mb-3">{t(lang, `how.${step.id}.title`)}</h3>
          <p class="text-[14.5px] text-muted-strong leading-relaxed">{t(lang, `how.${step.id}.desc`)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
