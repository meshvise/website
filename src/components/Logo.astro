---
interface Props {
  class?: string;
}
const { class: className = 'w-6 h-6' } = Astro.props;
---

<!--
  Meshvise logo : M letter (currentColor, themeable per call site) plus
  3 mesh circuit nodes (#1FA8FF brand blue, hardcoded). Source path data
  copied from Meshvise/brand/logo.svg (vector source via potrace, identical
  visual to the PNG variant served at /logo.png for OG / apple-touch-icon).

  viewBox 280 270 700 700 = tight crop on content with intentional ~6%
  vertical breathing so the M sits slightly below center (avoids the
  off-center top-heavy feeling of a perfect-center crop).
-->
