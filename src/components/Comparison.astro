---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const rows = [
  { criterion: 'tag_pricing',     wg: 'no',     ng: 'yes_5',  ig: 'yes_lite', ec: 'yes_pro' },
  { criterion: 'data_storage',    wg: 'pg',     ng: 'proprio', ig: 'proprio', ec: 'proprio' },
  { criterion: 'bi_connector',    wg: 'native', ng: 'export',  ig: 'odbc',     ec: 'export'  },
  { criterion: 'self_host',       wg: 'docker', ng: 'jvm',     ig: 'jvm',     ec: 'cloud'    },
  { criterion: 'config_versioning', wg: 'git',  ng: 'manual',  ig: 'manual',  ec: 'manual'   },
  { criterion: 'protocols',       wg: 'p3',     ng: 'p20',     ig: 'p20',     ec: 'p15'      },
  { criterion: 'startup_cost',    wg: 'free',   ng: '5k',      ig: '4k',      ec: 'quote'    },
];

const isWiregridGood = (val: string) =>
  ['no', 'pg', 'native', 'docker', 'git', 'yes', 'free'].includes(val);
---

<section id="comparison" class="px-6 py-24 md:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <div class="section-eyebrow justify-center">{t(lang, 'comparison.eyebrow')}</div>
      <h2 class="section-title">{t(lang, 'comparison.title')}</h2>
      <p class="section-lede mx-auto">{t(lang, 'comparison.subtitle')}</p>
    </div>

    <div class="rounded-lg border border-border bg-surface overflow-hidden shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-[14.5px] min-w-[640px]">
          <thead>
            <tr class="border-b border-border" style="background:var(--color-surface-hi);">
              <th class="text-left py-3.5 pl-5 pr-4 text-[11px] uppercase tracking-[0.08em] text-muted font-semibold">
                {t(lang, 'comparison.col.criterion')}
              </th>
              <th class="text-left py-3.5 px-4 font-semibold text-text">Wiregrid</th>
              <th class="text-left py-3.5 px-4 font-medium text-muted-strong">Niagara&nbsp;N4</th>
              <th class="text-left py-3.5 px-4 font-medium text-muted-strong">Ignition</th>
              <th class="text-left py-3.5 px-4 pr-5 font-medium text-muted-strong">EcoStruxure</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr class="border-b border-border/70 last:border-0">
                <th scope="row" class="text-left py-3.5 pl-5 pr-4 font-medium text-text">
                  {t(lang, `comparison.criterion.${row.criterion}`)}
                </th>
                <td class={`py-3.5 px-4 font-medium ${isWiregridGood(row.wg) ? 'text-text' : 'text-muted-strong'}`} style={isWiregridGood(row.wg) ? 'background:rgb(6 182 212 / 0.04);' : ''}>
                  <span class="inline-flex items-center gap-1.5">
                    {isWiregridGood(row.wg) && (
                      <svg class="w-3.5 h-3.5 text-brand shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <polyline points="3 8 7 12 13 4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                    <span>{t(lang, `comparison.value.${row.wg}`)}</span>
                  </span>
                </td>
                <td class="py-3.5 px-4 text-muted">{t(lang, `comparison.value.${row.ng}`)}</td>
                <td class="py-3.5 px-4 text-muted">{t(lang, `comparison.value.${row.ig}`)}</td>
                <td class="py-3.5 px-4 pr-5 text-muted">{t(lang, `comparison.value.${row.ec}`)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-5 text-center text-[12px] text-muted">{t(lang, 'comparison.disclaimer')}</p>
  </div>
</section>
