---
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const label = lang === 'fr'
  ? 'Interopérabilité terrain et outils d\'analyse'
  : 'Field equipment and analytics interoperability';
---

<section class="py-12 px-6 border-y border-border/50">
  <div class="mx-auto max-w-5xl">
    <p class="text-center text-xs text-muted uppercase tracking-widest mb-8">{label}</p>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:gap-x-14">

      <!-- Siemens -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="Siemens">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="11" stroke="#009999" stroke-width="2"/>
          <path d="M7 12h10M12 7v10" stroke="#009999" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">Siemens</span>
      </div>

      <!-- Schneider Electric -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="Schneider Electric">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <rect x="2" y="2" width="20" height="20" rx="3" stroke="#3DCD58" stroke-width="2"/>
          <path d="M8 8l8 8M16 8l-8 8" stroke="#3DCD58" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">Schneider</span>
      </div>

      <!-- Wago -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="Wago">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="6" width="18" height="12" rx="2" stroke="#FF6600" stroke-width="2"/>
          <path d="M8 10v4M12 10v4M16 10v4" stroke="#FF6600" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">Wago</span>
      </div>

      <!-- ABB -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="ABB">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <rect x="2" y="4" width="20" height="16" rx="3" stroke="#FF000F" stroke-width="2"/>
          <path d="M7 14l2-4 2 4M15 10v4M17 10v4" stroke="#FF000F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">ABB</span>
      </div>

      <div class="hidden md:block w-px h-6 bg-border"></div>

      <!-- Power BI -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="Power BI">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <rect x="14" y="4" width="4" height="16" rx="1" fill="#F2C811"/>
          <rect x="9" y="8" width="4" height="12" rx="1" fill="#F2C811" opacity="0.7"/>
          <rect x="4" y="12" width="4" height="8" rx="1" fill="#F2C811" opacity="0.4"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">Power BI</span>
      </div>

      <!-- Grafana -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="Grafana">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="#F46800" stroke-width="2"/>
          <circle cx="12" cy="12" r="4" stroke="#F46800" stroke-width="2"/>
          <path d="M12 2v4M12 18v4M2 12h4M18 12h4" stroke="#F46800" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">Grafana</span>
      </div>

      <!-- Excel -->
      <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-opacity" title="Microsoft Excel">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="3" width="18" height="18" rx="2" stroke="#217346" stroke-width="2"/>
          <path d="M8 8l8 8M16 8l-8 8" stroke="#217346" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="text-sm font-medium text-muted-strong tracking-wide">Excel</span>
      </div>

    </div>
  </div>
</section>
