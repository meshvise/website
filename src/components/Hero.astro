---
import { t, type Lang } from '../i18n';
import AppPreview from './AppPreview.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="pt-32 pb-12 px-6">
  <div class="mx-auto max-w-5xl text-center">
    <div
      class="inline-block mb-6 px-4 py-1.5 rounded-full border border-brand/30 bg-brand/5 text-brand text-xs font-medium tracking-wide uppercase"
    >
      {t(lang, 'hero.eyebrow')}
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05]">
      <span set:html={t(lang, 'hero.title_html')} />
    </h1>

    <p class="mt-6 text-lg md:text-xl text-muted-strong max-w-3xl mx-auto leading-relaxed">
      {t(lang, 'hero.subtitle')}
    </p>

    <ul class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-muted">
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        {t(lang, 'hero.bullet_1')}
      </li>
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        {t(lang, 'hero.bullet_2')}
      </li>
      <li class="flex items-center gap-2">
        <svg class="w-4 h-4 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        {t(lang, 'hero.bullet_3')}
      </li>
    </ul>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://demo.wiregrid.fr" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"/></svg>
        {t(lang, 'hero.cta_demo')}
      </a>
      <a href={`/${lang}/#pricing`} class="btn btn-outline btn-lg">
        {t(lang, 'hero.cta_pricing')}
      </a>
    </div>

    <p class="mt-3 text-xs text-muted">{t(lang, 'hero.cta_note')}</p>

    <div class="mt-14">
      <AppPreview lang={lang} />
    </div>
  </div>
</section>
