---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const pillars = [
  {
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`,
    title: t(lang, 'values.simple_title'),
    desc: t(lang, 'values.simple_desc'),
  },
  {
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z"/></svg>`,
    title: t(lang, 'values.open_title'),
    desc: t(lang, 'values.open_desc'),
  },
  {
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
    title: t(lang, 'values.affordable_title'),
    desc: t(lang, 'values.affordable_desc'),
  },
];
---

<section class="py-20 px-6">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-semibold text-center mb-4">{t(lang, 'values.title')}</h2>
    <p class="text-center text-muted text-lg mb-16 max-w-2xl mx-auto">
      {lang === 'fr'
        ? 'Wiregrid est conçu pour les sites industriels et tertiaires qui ont besoin de supervision sans la complexité et le coût des solutions traditionnelles.'
        : 'Wiregrid is designed for industrial and commercial sites that need supervision without the complexity and cost of traditional solutions.'}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {pillars.map((p) => (
        <div class="border border-border rounded-md p-8 bg-surface hover:border-brand/40 transition-colors group">
          <div class="text-brand group-hover:text-brand-hover transition-colors">
            <Fragment set:html={p.icon} />
          </div>
          <h3 class="mt-5 text-xl font-semibold">{p.title}</h3>
          <p class="mt-3 text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
