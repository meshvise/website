---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Pricing structured for Schema.org Product/Offer JSON-LD downstream.
// Numbers are placeholders the founder can adjust — kept concrete on
// purpose because "On request" tanks both AI-search citation and
// outbound-marketing trust.
const tiers = [
  {
    id: 'free',
    highlight: false,
    cta_href: 'https://demo.wiregrid.fr',
    cta_external: true,
    features: [
      'feature.points_50',
      'feature.protocols_modbus',
      'feature.historian_7d',
      'feature.alarms',
      'feature.api_open',
      'feature.support_docs',
    ],
  },
  {
    id: 'pro',
    highlight: true,
    cta_href: 'mailto:contact@wiregrid.fr?subject=Wiregrid%20Pro',
    cta_external: false,
    features: [
      'feature.points_unlimited',
      'feature.protocols_all',
      'feature.historian_unlimited',
      'feature.alarms_notifications',
      'feature.api_open',
      'feature.support_dedicated',
      'feature.priority_roadmap',
    ],
  },
];
---

<section id="pricing" class="py-20 px-6 bg-surface border-t border-border">
  <div class="mx-auto max-w-4xl">
    <div class="max-w-2xl mb-14">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">{t(lang, 'pricing.title')}</h2>
      <p class="mt-4 text-muted-strong leading-relaxed">{t(lang, 'pricing.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {tiers.map((tier) => (
        <div class={`rounded-md p-8 bg-bg ${tier.highlight ? 'border-2 border-brand relative' : 'border border-border'}`}>
          {tier.highlight && (
            <div class="absolute -top-3 left-6 bg-brand text-bg text-[10px] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-sm">
              {t(lang, 'pricing.recommended')}
            </div>
          )}

          <h3 class="text-2xl font-semibold">{t(lang, `pricing.${tier.id}.name`)}</h3>
          <p class="text-muted mt-2 text-sm leading-relaxed">{t(lang, `pricing.${tier.id}.tagline`)}</p>

          <div class="mt-6 flex items-baseline gap-2">
            <span class="text-4xl font-semibold text-text">{t(lang, `pricing.${tier.id}.price`)}</span>
            <span class="text-sm text-muted">{t(lang, `pricing.${tier.id}.period`)}</span>
          </div>
          <p class="text-xs text-muted mt-1">{t(lang, `pricing.${tier.id}.price_note`)}</p>

          <ul class="mt-8 space-y-3 text-sm">
            {tier.features.map((feat) => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 text-brand shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-muted-strong">{t(lang, `pricing.${feat}`)}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8">
            <a
              href={tier.cta_href}
              {...(tier.cta_external ? { target: '_blank', rel: 'noopener' } : {})}
              class={`btn ${tier.highlight ? 'btn-primary' : 'btn-outline'} w-full justify-center`}
            >
              {t(lang, `pricing.${tier.id}.cta`)}
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-8 text-xs text-muted text-center">{t(lang, 'pricing.footnote')}</p>
  </div>
</section>
